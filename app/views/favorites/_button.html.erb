<%# locals: (product:) %>

<div id="favorite_button_<%= product.id %>" class="favorite-heart-wrapper">
  <% if authenticated? %>
    <% if current_user.favorited?(product) %>
      <%= button_to product_favorite_path(product), method: :delete, class: "btn-favorite-heart active", title: "Remover dos favoritos", data: { turbo_frame: "_self" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" class="lucide lucide-heart text-danger"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
      <% end %>
    <% else %>
      <%= button_to product_favorite_path(product), method: :post, class: "btn-favorite-heart", title: "Adicionar aos favoritos", data: { turbo_frame: "_self" } do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-heart"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
      <% end %>
    <% end %>
  <% else %>
    <%= button_to product_favorite_path(product), method: :post, class: "btn-favorite-heart", title: "Faça login para favoritar", data: { turbo: false } do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="lucide lucide-heart"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
    <% end %>
  <% end %>
</div>
