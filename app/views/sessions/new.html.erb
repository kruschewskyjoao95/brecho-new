<div class="checkout-box" style="max-width: 380px; margin: 40px auto; padding: 28px;">
  
  <div style="text-align: center; margin-bottom: 24px;">
    <h1 style="font-family: var(--font-serif); color: var(--primary); margin-bottom: 6px; font-size: 1.8rem;">Área Restrita</h1>
    <p style="color: var(--text-muted); font-size: 0.9rem;">
      Identifique-se para acessar o painel do lookbook.
    </p>
  </div>

  <%= form_with url: session_path, local: true do |form| %>
    <div class="form-group">
      <%= form.label :email_address, "E-mail de Acesso", class: "form-label" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "seu@email.com", value: params[:email_address], class: "form-control" %>
    </div>

    <div class="form-group" style="margin-bottom: 10px;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
        <%= form.label :password, "Senha", class: "form-label", style: "margin-bottom:0;" %>
        <%= link_to "Esqueci a senha", new_password_path, style: "font-size:0.8rem; color:var(--accent);" %>
      </div>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Sua senha", maxlength: 72, class: "form-control", style: "margin-top:6px;" %>
    </div>

    <div style="margin-top: 24px; text-align: center;">
      <%= form.submit "Entrar no Painel", class: "btn btn-primary btn-sm", style: "padding: 10px 24px; width: auto;" %>
    </div>
  <% end %>

  <div style="margin-top: 25px; text-align: center; font-size: 0.85rem; color: var(--text-muted); border-top: 1px solid var(--border-color); padding-top: 20px;">
    <p>Dica para desenvolvimento:</p>
    <strong>Login:</strong> <code>contato@amelialookbook.com.br</code> <br>
    <strong>Senha:</strong> <code>password123</code>
  </div>

</div>
