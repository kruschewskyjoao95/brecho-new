<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Brechó Ruby - Lookbook & Bazar" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Brechó Ruby">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body data-controller="cart-drawer">
    <!-- Header -->
    <header class="main-header">
      <div class="container header-container">
        <div class="logo">
          <%= link_to root_path do %>
            <span class="brand-name">Brechó Ruby</span>
            <span class="brand-sub">Lookbook</span>
          <% end %>
        </div>

        <div class="header-actions" style="display:flex; align-items:center; gap:16px;">
          <% if authenticated? %>
            <% if current_user.admin? || current_user.seller? %>
              <%= link_to "Painel", admin_products_path, class: "nav-link", style: "font-size: 0.9rem;" %>
            <% end %>
            <%= link_to "Ofertas", admin_offers_path, class: "nav-link", style: "font-size: 0.9rem; color:var(--accent);" %>
            <%= link_to "Favoritos", favorites_path, class: "nav-link", style: "font-size: 0.9rem;" %>
            <%= link_to "Perfil", edit_profile_path, class: "nav-link", style: "font-size: 0.9rem;" %>
            <%= button_to "Sair", session_path, method: :delete, class: "filter-btn", style: "padding: 6px 12px; font-size: 0.8rem; border-color: var(--border-color); background:transparent;" %>
          <% else %>
            <%= link_to "Entrar", new_session_path, class: "nav-link", style: "font-size: 0.9rem;" %>
            <%= link_to "Criar Conta", new_registration_path, class: "nav-link", style: "font-size: 0.9rem;" %>
          <% end %>

          <!-- Botão Carrinho -->
          <a href="#" class="btn btn-outline btn-sm" data-action="click->cart-drawer#open">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shopping-bag"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            Sacola (<span id="cart-counter"><%= @cart.total_items_count %></span>)
          </a>
        </div>
      </div>
    </header>

    <!-- Flash Messages -->
    <div class="container">
      <% if flash[:notice] %>
        <div class="flash-message flash-notice">
          <span><%= flash[:notice] %></span>
          <button onclick="this.parentElement.remove()" style="background:none; border:none; cursor:pointer; color:inherit; font-weight:bold;">&times;</button>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="flash-message flash-alert">
          <span><%= flash[:alert] %></span>
          <button onclick="this.parentElement.remove()" style="background:none; border:none; cursor:pointer; color:inherit; font-weight:bold;">&times;</button>
        </div>
      <% end %>
    </div>

    <!-- Main Content -->
    <main class="container">
      <%= yield %>
    </main>

    <!-- Shopping Cart Backdrop & Drawer -->
    <div class="cart-drawer-backdrop" data-cart-drawer-target="backdrop" data-action="click->cart-drawer#close"></div>
    <div class="cart-drawer" data-cart-drawer-target="drawer">
      <div class="cart-drawer-header">
        <h2>Minha Sacola</h2>
        <button class="cart-drawer-close" data-action="click->cart-drawer#close">&times;</button>
      </div>

      <%= turbo_frame_tag "cart_drawer_content" do %>
        <div class="cart-drawer-items">
          <% if @cart.cart_items.empty? %>
            <p style="text-align: center; color: var(--text-muted); margin-top: 40px;">Sua sacola está vazia.</p>
          <% else %>
            <% @cart.cart_items.includes(:product).each do |item| %>
              <div class="cart-drawer-item">
                <% if item.product.images.attached? %>
                  <%= image_tag item.product.images.first, class: "cart-item-img" %>
                <% else %>
                  <div class="cart-item-img" style="background-color: #eae5e1; display:flex; align-items:center; justify-content:center; font-size:10px; color:var(--text-muted);">Sem foto</div>
                <% end %>
                <div class="cart-item-details">
                  <h4 class="cart-item-title"><%= item.product.name %></h4>
                  <div class="cart-item-meta">Tam: <%= item.size %> | Cor: <%= item.color %> | Qtd: <%= item.quantity %></div>
                  <div class="cart-item-price-row">
                    <span class="cart-item-price">R$ <%= number_with_precision(item.total, precision: 2) %></span>
                    <%= button_to cart_item_path(item), method: :delete, class: "cart-drawer-close", style: "font-size:1.2rem;", data: { turbo_frame: "cart_drawer_content" } do %>
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trash-2"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                    <% end %>
                  </div>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>

        <div class="cart-drawer-footer">
          <div class="cart-total-row">
            <span>Subtotal:</span>
            <span>R$ <%= number_with_precision(@cart.total, precision: 2) %></span>
          </div>
          <% unless @cart.cart_items.empty? %>
            <%= link_to "Finalizar Compra", new_order_path, class: "btn btn-primary", style: "width: 100%; display: block; text-align: center; box-sizing: border-box;", data: { turbo: false } %>
          <% end %>
        </div>
      <% end %>
    </div>



    <!-- Footer -->
    <footer style="margin-top: 80px; padding: 40px 0; border-top: 1px solid var(--border-color); text-align: center; color: var(--text-muted); font-size: 0.9rem;">
      <p>&copy; <%= Time.current.year %> Brechó Ruby. Todos os direitos reservados.</p>
      <p style="margin-top: 8px; font-size: 0.8rem;">Desenvolvido com Ruby on Rails 8 & Hotwire.</p>
    </footer>
  </body>
</html>
