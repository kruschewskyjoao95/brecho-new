<div class="lookbook-title-sec" style="padding: 40px 0 20px; display:flex; justify-content:space-between; align-items:center; text-align:left;">
  <div>
    <h1>Painel Financeiro</h1>
    <p>Acompanhe suas vendas, comissão da plataforma e solicite transferências (saques)</p>
  </div>
</div>

<div style="display: flex; gap: 20px; margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">
  <%= link_to "Minhas Peças", admin_products_path, style: "padding-bottom: 8px; color: var(--text-muted);" %>
  <%= link_to "Minhas Vendas", admin_sales_path, style: "padding-bottom: 8px; color: var(--text-muted);" %>
  <%= link_to "Financeiro", admin_financial_path, style: "font-weight: bold; border-bottom: 2px solid var(--primary); padding-bottom: 8px; color: var(--primary);" %>
</div>

<!-- Balances Grid -->
<div class="checkout-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
  
  <!-- Saldo Bloqueado Card -->
  <div class="checkout-box" style="background: white; border-radius: var(--radius); padding: 30px; border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; justify-content: space-between;">
    <div>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
        <h3 style="font-family: var(--font-serif); color: var(--primary); border: none; padding: 0; margin: 0; font-size: 1.3rem;">Saldo Bloqueado</h3>
        <span style="font-size: 0.75rem; background-color: #f7ede2; color: #b25353; padding: 4px 8px; border-radius: 4px; font-weight: bold; text-transform: uppercase;">Aguardando Envio/Entrega</span>
      </div>
      <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 20px;">
        Valores de vendas já confirmadas pela plataforma, descontada a taxa de 10% do Brechó, mas que aguardam o comprador confirmar o recebimento do pacote.
      </p>
    </div>
    <div style="font-size: 2.2rem; font-weight: bold; color: var(--primary); font-family: var(--font-sans);">
      R$ <%= number_with_precision(@user.saldo_bloqueado, precision: 2) %>
    </div>
  </div>

  <!-- Saldo Disponível Card -->
  <div class="checkout-box" style="background: white; border-radius: var(--radius); padding: 30px; border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; justify-content: space-between;">
    <div>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
        <h3 style="font-family: var(--font-serif); color: var(--success); border: none; padding: 0; margin: 0; font-size: 1.3rem;">Saldo Disponível</h3>
        <span style="font-size: 0.75rem; background-color: #eaf2eb; color: var(--success); padding: 4px 8px; border-radius: 4px; font-weight: bold; text-transform: uppercase;">Liberado para Saque</span>
      </div>
      <p style="font-size: 0.95rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 20px;">
        Valores de vendas cujas entregas já foram confirmadas pelo comprador (ou entregas realizadas há mais de 7 dias) prontas para serem retiradas.
      </p>
    </div>
    <div style="font-size: 2.2rem; font-weight: bold; color: var(--success); font-family: var(--font-sans);">
      R$ <%= number_with_precision(@user.saldo_disponivel, precision: 2) %>
    </div>
  </div>

</div>

<!-- Lower Section Grid -->
<div class="checkout-grid" style="display: grid; grid-template-columns: 2fr 1fr; gap: 30px; margin-top: 30px;">
  
  <!-- Column 1: Payout History -->
  <div>
    <h3 style="font-family: var(--font-serif); color: var(--primary); font-size: 1.4rem; margin-bottom: 15px; border-bottom: 1px solid var(--border-color); padding-bottom: 8px;">Histórico de Saques</h3>
    
    <table class="admin-table" style="margin-top: 0; box-shadow: none; border: 1px solid var(--border-color);">
      <thead>
        <tr>
          <th>Código</th>
          <th>Solicitado em</th>
          <th>Valor</th>
          <th>Chave Pix</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% if @payouts.any? %>
          <% @payouts.each do |payout| %>
            <tr>
              <td><strong>#<%= payout.id %></strong></td>
              <td><%= payout.created_at.strftime("%d/%m/%Y %H:%M") %></td>
              <td style="font-weight: 600; color: var(--primary);">R$ <%= number_with_precision(payout.amount, precision: 2) %></td>
              <td>
                <span style="font-size:0.75rem; color:var(--text-muted); text-transform:uppercase;"><%= payout.pix_key_type %></span> <br>
                <code style="font-family: monospace; font-size: 0.85rem;"><%= payout.pix_key %></code>
              </td>
              <td>
                <% status_colors = { 'pending' => 'orange', 'paid' => 'green', 'cancelled' => 'red' } %>
                <% status_names = { 'pending' => 'Pendente', 'paid' => 'Pago', 'cancelled' => 'Cancelado' } %>
                <span class="badge-tag" style="position:static; background-color: <%= status_colors[payout.status] || 'gray' %>;">
                  <%= status_names[payout.status] || payout.status.titleize %>
                </span>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="5" style="text-align:center; padding: 40px; color:var(--text-muted); font-style:italic;">
              Nenhuma solicitação de saque realizada ainda.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <!-- Column 2: Request Payout Form -->
  <div>
    <div class="order-summary-box" style="background: white; padding: 25px; border-radius: var(--radius); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); position: sticky; top: 20px;">
      <h3 style="color: var(--primary); margin-bottom: 15px; border:none; padding:0;">Solicitar Saque</h3>
      
      <% if @user.saldo_disponivel > 0 %>
        <%= form_with model: @payout, url: admin_payouts_path, method: :post, local: true do |f| %>
          
          <div class="form-group" style="margin-bottom: 16px;">
            <%= f.label :amount, "Valor do Saque (R$)", class: "form-label" %>
            <%= f.number_field :amount, min: 0.01, max: @user.saldo_disponivel, step: 0.01, value: @user.saldo_disponivel, class: "form-control", required: true %>
            <span style="font-size: 0.75rem; color: var(--text-muted); display: block; margin-top: 4px;">
              Máximo disponível: R$ <%= number_with_precision(@user.saldo_disponivel, precision: 2) %>
            </span>
          </div>

          <div class="form-group" style="margin-bottom: 16px;">
            <%= f.label :pix_key_type, "Tipo de Chave Pix", class: "form-label" %>
            <%= f.select :pix_key_type, [['CPF/CNPJ', 'cpf'], ['E-mail', 'email'], ['Telefone', 'phone'], ['Chave Aleatória', 'random']], {}, class: "form-control", required: true %>
          </div>

          <div class="form-group" style="margin-bottom: 20px;">
            <%= f.label :pix_key, "Chave Pix", class: "form-label" %>
            <%= f.text_field :pix_key, placeholder: "Digite sua chave Pix", class: "form-control", required: true %>
          </div>

          <%= f.submit "Transferir para minha Conta", class: "btn btn-primary", style: "width:100%; padding: 12px; font-size: 1rem;" %>
        <% end %>
      <% else %>
        <div style="text-align: center; padding: 20px 10px; color: var(--text-muted); font-style: italic; border: 1px dashed var(--border-color); border-radius: var(--radius-sm); background: #faf8f6;">
          Você não possui saldo disponível para saque no momento. Assim que os clientes confirmarem a entrega de novos pedidos, o saldo será liberado aqui!
        </div>
      <% end %>
      
    </div>
  </div>

</div>
