# -----------------------------------------------------------------------------
# ARQUIVO DE EXEMPLO PARA VARIÁVEIS DE AMBIENTE (.env.example)
# -----------------------------------------------------------------------------
# Como usar:
# 1. Copie este arquivo renomeando-o para ".env" (sem a palavra .example)
#    Comando: cp .env.example .env
# 2. Preencha os valores das chaves com os dados reais do seu ambiente.
# 3. O arquivo ".env" é ignorado pelo Git automaticamente por motivos de segurança.
# -----------------------------------------------------------------------------

# Chave da API do Gateway de Pagamento (Asaas)
# Em ambiente de desenvolvimento, coloque sua chave do Sandbox
# Em produção, utilize a chave real
ASAAS_API_KEY=sua_chave_api_do_asaas_aqui

# Controle de Log (Nível do Logger)
# Opções: debug, info, warn, error, fatal
RAILS_LOG_LEVEL=info

# (Opcional) Database e Outros
# O banco padrão deste projeto é SQLite. Se um dia migrar para Postgresql:
# DATABASE_URL=postgres://usuario:senha@localhost/brecho_ruby_production

# (Opcional) Chave mestre para criptografia de Credentials 
# Se preferir usar .env em vez de master.key em produção
# RAILS_MASTER_KEY=sua_master_key_gerada
